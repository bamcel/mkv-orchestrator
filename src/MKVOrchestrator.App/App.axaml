<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="using:MKVOrchestrator.App.Converters"
             x:Class="MKVOrchestrator.App.App">

<Application.Resources>

<SolidColorBrush x:Key="ThemeWindowBackgroundBrush" Color="#1E1F29"/>
<SolidColorBrush x:Key="ThemeCardBackgroundBrush" Color="#282A36"/>
<SolidColorBrush x:Key="ThemePanelBackgroundBrush" Color="#2B2E3A"/>
<SolidColorBrush x:Key="ThemeSidebarBackgroundBrush" Color="#232631"/>
<SolidColorBrush x:Key="ThemeInputBackgroundBrush" Color="#282A36"/>
<SolidColorBrush x:Key="ThemeInputHoverBackgroundBrush" Color="#2F3140"/>
<SolidColorBrush x:Key="ThemeButtonBackgroundBrush" Color="#44475A"/>
<SolidColorBrush x:Key="ThemeButtonHoverBackgroundBrush" Color="#BD93F9"/>
<SolidColorBrush x:Key="ThemeSelectedBackgroundBrush" Color="#3A3D4F"/>
<SolidColorBrush x:Key="ThemeBorderBrush" Color="#343746"/>
<SolidColorBrush x:Key="ThemeBorderStrongBrush" Color="#44475A"/>
<SolidColorBrush x:Key="ThemeTextBrush" Color="#F8F8F2"/>
<SolidColorBrush x:Key="ThemeMutedTextBrush" Color="#CFCFEA"/>
<SolidColorBrush x:Key="ThemeSubtleTextBrush" Color="#8B93A7"/>
<SolidColorBrush x:Key="ThemeAccentBrush" Color="#BD93F9"/>
<SolidColorBrush x:Key="ThemeAppTitleBrush" Color="#BD93F9"/>
<SolidColorBrush x:Key="ThemeSuccessBrush" Color="#50FA7B"/>
<SolidColorBrush x:Key="ThemeWarningBrush" Color="#FFA500"/>
<SolidColorBrush x:Key="ThemeDisabledTextBrush" Color="#6272A4"/>

<!-- DataGrid focus/selection outline brushes -->
<SolidColorBrush x:Key="DataGridCellFocusVisualPrimaryBrush" Color="Transparent"/>
<SolidColorBrush x:Key="DataGridCellFocusVisualSecondaryBrush" Color="Transparent"/>
<SolidColorBrush x:Key="DataGridCellSelectedBorderBrush" Color="Transparent"/>

<!-- DataGrid selected-row colors: keep focused and unfocused selection from switching to default dull gray. -->
<SolidColorBrush x:Key="DataGridRowSelectedBackgroundBrush" Color="#3A3D4F"/>
<SolidColorBrush x:Key="DataGridRowSelectedUnfocusedBackgroundBrush" Color="#3A3D4F"/>
<SolidColorBrush x:Key="DataGridRowSelectedForegroundBrush" Color="#F8F8F2"/>
<SolidColorBrush x:Key="DataGridRowSelectedUnfocusedForegroundBrush" Color="#F8F8F2"/>
<SolidColorBrush x:Key="DataGridCellSelectedBackgroundBrush" Color="#3A3D4F"/>
<SolidColorBrush x:Key="DataGridCellSelectedUnfocusedBackgroundBrush" Color="#3A3D4F"/>
<SolidColorBrush x:Key="DataGridCellSelectedForegroundBrush" Color="#F8F8F2"/>
<SolidColorBrush x:Key="DataGridCellSelectedUnfocusedForegroundBrush" Color="#F8F8F2"/>
<SolidColorBrush x:Key="DataGridColumnHeaderForegroundBrush" Color="#F8F8F2"/>
<SolidColorBrush x:Key="DataGridRowForegroundBrush" Color="#F8F8F2"/>
<SolidColorBrush x:Key="DataGridCellForegroundBrush" Color="#F8F8F2"/>
<SolidColorBrush x:Key="SystemControlHighlightAccentBrush" Color="#3A3D4F"/>
<SolidColorBrush x:Key="SystemControlHighlightListAccentLowBrush" Color="#3A3D4F"/>
<SolidColorBrush x:Key="SystemControlHighlightListAccentMediumBrush" Color="#3A3D4F"/>
<SolidColorBrush x:Key="SystemControlHighlightListAccentHighBrush" Color="#3A3D4F"/>

<SolidColorBrush x:Key="DataGridFocusVisualPrimaryBrush" Color="Transparent"/>
<SolidColorBrush x:Key="DataGridFocusVisualSecondaryBrush" Color="Transparent"/>
<converters:VisualStateBrushConverter x:Key="VisualStateBrushConverter" />

<!-- Keep Fluent hover/pressed states from falling back to dark foregrounds on the dark MKVO theme. -->
<SolidColorBrush x:Key="ThemeForegroundBrush" Color="#F8F8F2"/>
<SolidColorBrush x:Key="SystemControlForegroundBaseHighBrush" Color="#F8F8F2"/>
<SolidColorBrush x:Key="SystemControlForegroundBaseMediumHighBrush" Color="#F8F8F2"/>
<SolidColorBrush x:Key="SystemControlForegroundBaseMediumBrush" Color="#F8F8F2"/>
<SolidColorBrush x:Key="SystemControlForegroundBaseLowBrush" Color="#CFCFEA"/>
<SolidColorBrush x:Key="SystemControlForegroundChromeHighBrush" Color="#F8F8F2"/>
<SolidColorBrush x:Key="SystemControlForegroundChromeBlackHighBrush" Color="#F8F8F2"/>
<SolidColorBrush x:Key="SystemControlForegroundChromeWhiteBrush" Color="#F8F8F2"/>
<SolidColorBrush x:Key="SystemControlHighlightAltBaseHighBrush" Color="#F8F8F2"/>
<SolidColorBrush x:Key="SystemControlHighlightAltBaseMediumHighBrush" Color="#F8F8F2"/>
<SolidColorBrush x:Key="SystemControlHighlightAltBaseMediumLowBrush" Color="#F8F8F2"/>
<SolidColorBrush x:Key="SystemControlHighlightAltChromeWhiteBrush" Color="#F8F8F2"/>
<Color x:Key="SystemAccentColor">#44475A</Color>
<SolidColorBrush x:Key="SystemAccentColorBrush" Color="#44475A"/>
<SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="#44475A"/>
<SolidColorBrush x:Key="AccentFillColorSecondaryBrush" Color="#505366"/>
<SolidColorBrush x:Key="AccentFillColorTertiaryBrush" Color="#343746"/>
<SolidColorBrush x:Key="AccentFillColorDisabledBrush" Color="#343746"/>
<SolidColorBrush x:Key="AccentTextFillColorPrimaryBrush" Color="#F8F8F2"/>

</Application.Resources>

  <Application.Styles>
    <FluentTheme />
    <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml" />
    <StyleInclude Source="avares://MKVOrchestrator.App/Themes/OrchestratorTheme.axaml" />
  </Application.Styles>
</Application>
