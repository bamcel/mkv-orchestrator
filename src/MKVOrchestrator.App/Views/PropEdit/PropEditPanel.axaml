<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MKVOrchestrator.App.ViewModels"
             x:Class="MKVOrchestrator.App.Views.PropEdit.PropEditPanel"
             x:DataType="vm:MainWindowViewModel">
        <Grid RowDefinitions="*" ColumnDefinitions="370,*" ColumnSpacing="12" Margin="0,12,0,0">
          <Border Classes="card" Grid.Row="0" Grid.Column="0" Padding="8">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,*" RowSpacing="4">
              <DockPanel Grid.Row="0" LastChildFill="False">
                <TextBlock Text="Properties Configuration" Classes="section-header" />
              </DockPanel>

              <TextBlock Grid.Row="1"
                         Text="Configure container title, video track name, and property edit behavior."
                         TextWrapping="Wrap"
                         Classes="muted"
                         FontSize="11"
                         Margin="0,0,0,6" />

              <TextBlock Grid.Row="2" Text="Template File" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource ThemeTextBrush}" Margin="0,5,0,1" />

              <StackPanel Grid.Row="3" Spacing="3" HorizontalAlignment="Left" Width="330">
                <TextBox Text="{Binding PropEditTemplateFileName}"
                         IsReadOnly="True"
                         Watermark="Select scanned file"
                         ToolTip.Tip="{Binding PropEditTemplateFilePath}"
                         MinHeight="36"
                         Padding="10,0,8,0" />
                <TextBlock Text="Uses template track order; validates before editing."
                           TextWrapping="Wrap"
                           Classes="muted"
                           FontSize="10" />
              </StackPanel>

              <TextBlock Grid.Row="4" Text="Container Title" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource ThemeTextBrush}" Margin="0,7,0,1" />

              <StackPanel Grid.Row="5" Spacing="3" HorizontalAlignment="Left" Width="330">
                <RadioButton Classes="mode-option"
                             GroupName="ContainerTitleMode"
                             IsChecked="{Binding PropRemoveContainerTitle}">
                  <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                    <Border Grid.Column="0" Classes="mode-check" IsVisible="{Binding PropRemoveContainerTitle}">
                      <TextBlock Text="✓" Classes="mode-checkmark" />
                    </Border>
                    <Border Grid.Column="0" Classes="mode-check-empty" IsVisible="{Binding !PropRemoveContainerTitle}" />
                    <TextBlock Grid.Column="1" Text="Remove title" Foreground="{DynamicResource ThemeTextBrush}" VerticalAlignment="Center" />
                  </Grid>
                </RadioButton>
                <RadioButton Classes="mode-option"
                             GroupName="ContainerTitleMode"
                             IsChecked="{Binding PropKeepContainerTitle}">
                  <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                    <Border Grid.Column="0" Classes="mode-check" IsVisible="{Binding PropKeepContainerTitle}">
                      <TextBlock Text="✓" Classes="mode-checkmark" />
                    </Border>
                    <Border Grid.Column="0" Classes="mode-check-empty" IsVisible="{Binding !PropKeepContainerTitle}" />
                    <TextBlock Grid.Column="1" Text="Keep existing title" Foreground="{DynamicResource ThemeTextBrush}" VerticalAlignment="Center" />
                  </Grid>
                </RadioButton>
                <RadioButton Classes="mode-option"
                             GroupName="ContainerTitleMode"
                             IsChecked="{Binding PropContainerTitleFromFile}">
                  <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                    <Border Grid.Column="0" Classes="mode-check" IsVisible="{Binding PropContainerTitleFromFile}">
                      <TextBlock Text="✓" Classes="mode-checkmark" />
                    </Border>
                    <Border Grid.Column="0" Classes="mode-check-empty" IsVisible="{Binding !PropContainerTitleFromFile}" />
                    <TextBlock Grid.Column="1" Text="Use file name" Foreground="{DynamicResource ThemeTextBrush}" VerticalAlignment="Center" />
                  </Grid>
                </RadioButton>
                <RadioButton Classes="mode-option"
                             GroupName="ContainerTitleMode"
                             IsChecked="{Binding PropContainerTitleCustom}">
                  <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                    <Border Grid.Column="0" Classes="mode-check" IsVisible="{Binding PropContainerTitleCustom}">
                      <TextBlock Text="✓" Classes="mode-checkmark" />
                    </Border>
                    <Border Grid.Column="0" Classes="mode-check-empty" IsVisible="{Binding !PropContainerTitleCustom}" />
                    <TextBlock Grid.Column="1" Text="Custom title" Foreground="{DynamicResource ThemeTextBrush}" VerticalAlignment="Center" />
                  </Grid>
                </RadioButton>
                <TextBox Text="{Binding PropCustomContainerTitle}"
                         MinHeight="36"
                         Padding="10,0,8,0" />
              </StackPanel>
              <TextBlock Grid.Row="6" Text="Video Track Name" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource ThemeTextBrush}" Margin="0,7,0,1" />

              <StackPanel Grid.Row="7" Spacing="3" HorizontalAlignment="Left" Width="330">
                <RadioButton Classes="mode-option"
                             GroupName="VideoTitleMode"
                             IsChecked="{Binding PropRemoveVideoTitle}">
                  <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                    <Border Grid.Column="0" Classes="mode-check" IsVisible="{Binding PropRemoveVideoTitle}">
                      <TextBlock Text="✓" Classes="mode-checkmark" />
                    </Border>
                    <Border Grid.Column="0" Classes="mode-check-empty" IsVisible="{Binding !PropRemoveVideoTitle}" />
                    <TextBlock Grid.Column="1" Text="Remove video name" Foreground="{DynamicResource ThemeTextBrush}" VerticalAlignment="Center" />
                  </Grid>
                </RadioButton>
                <RadioButton Classes="mode-option"
                             GroupName="VideoTitleMode"
                             IsChecked="{Binding PropKeepVideoTitle}">
                  <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                    <Border Grid.Column="0" Classes="mode-check" IsVisible="{Binding PropKeepVideoTitle}">
                      <TextBlock Text="✓" Classes="mode-checkmark" />
                    </Border>
                    <Border Grid.Column="0" Classes="mode-check-empty" IsVisible="{Binding !PropKeepVideoTitle}" />
                    <TextBlock Grid.Column="1" Text="Keep existing name" Foreground="{DynamicResource ThemeTextBrush}" VerticalAlignment="Center" />
                  </Grid>
                </RadioButton>
                <RadioButton Classes="mode-option"
                             GroupName="VideoTitleMode"
                             IsChecked="{Binding PropVideoTitleFromFile}">
                  <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                    <Border Grid.Column="0" Classes="mode-check" IsVisible="{Binding PropVideoTitleFromFile}">
                      <TextBlock Text="✓" Classes="mode-checkmark" />
                    </Border>
                    <Border Grid.Column="0" Classes="mode-check-empty" IsVisible="{Binding !PropVideoTitleFromFile}" />
                    <TextBlock Grid.Column="1" Text="Use file name" Foreground="{DynamicResource ThemeTextBrush}" VerticalAlignment="Center" />
                  </Grid>
                </RadioButton>
                <RadioButton Classes="mode-option"
                             GroupName="VideoTitleMode"
                             IsChecked="{Binding PropVideoTitleCustom}">
                  <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                    <Border Grid.Column="0" Classes="mode-check" IsVisible="{Binding PropVideoTitleCustom}">
                      <TextBlock Text="✓" Classes="mode-checkmark" />
                    </Border>
                    <Border Grid.Column="0" Classes="mode-check-empty" IsVisible="{Binding !PropVideoTitleCustom}" />
                    <TextBlock Grid.Column="1" Text="Custom video name" Foreground="{DynamicResource ThemeTextBrush}" VerticalAlignment="Center" />
                  </Grid>
                </RadioButton>
                <TextBox Text="{Binding PropCustomVideoTitle}"
                         MinHeight="36"
                         Padding="10,0,8,0" />
              </StackPanel>
              <TextBlock Grid.Row="8" Text="Execution" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource ThemeTextBrush}" Margin="0,7,0,1" />

              <StackPanel Grid.Row="9"
                          Orientation="Horizontal"
                          Spacing="6"
                          Margin="0,4,0,0"
                          HorizontalAlignment="Left">
                <Button Content="Preview" Width="96" Command="{Binding DryRunCommand}" />
                <Button Content="Apply" Width="96" Command="{Binding ApplyCommand}" />
              </StackPanel>
            </Grid>
          </Border>

          <Grid Grid.Row="0" Grid.Column="1" RowDefinitions="*,190" RowSpacing="12">
          <Border Classes="card" Grid.Row="0">
            <Grid RowDefinitions="Auto,*,*" RowSpacing="10">
              <TextBlock Grid.Row="0" Text="Track Properties" Classes="section-header" />

              <Border Grid.Row="1" Classes="panel" MinHeight="120">
                <Grid RowDefinitions="Auto,Auto,*">
                  <TextBlock Grid.Row="0" Text="Audio Tracks" Classes="section-header" />
                  <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8" VerticalAlignment="Center">
                    <TextBlock Text="Set default track" VerticalAlignment="Center" />
                    <ComboBox ItemsSource="{Binding DefaultAudioOptions}" SelectedItem="{Binding SelectedDefaultAudio}" Width="170" />
                  </StackPanel>
                  <DataGrid Grid.Row="2"
                            ItemsSource="{Binding PropEditAudioTracks}"
                            AutoGenerateColumns="False"
                            IsReadOnly="False"
                            ScrollViewer.VerticalScrollBarVisibility="Auto"
                            ScrollViewer.HorizontalScrollBarVisibility="Auto"
                            HorizontalAlignment="Stretch">
                    <DataGrid.Columns>
                      <DataGridTextColumn Header="Track" Binding="{Binding TrackLabel}" Width="110" IsReadOnly="True" />
                      <DataGridTemplateColumn Header="Custom" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                          <DataTemplate>
                            <CheckBox IsChecked="{Binding UseCustomName, Mode=TwoWay}"
                                      HorizontalAlignment="Left"
                                      VerticalAlignment="Center"
                                      Margin="8,0,0,0" />
                          </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                      </DataGridTemplateColumn>
                      <DataGridTemplateColumn Header="Name" Width="260">
                        <DataGridTemplateColumn.CellTemplate>
                          <DataTemplate>
                            <Grid>
                              <ComboBox Classes="trackNameEditor"
                                        ItemsSource="{Binding NameOptions}"
                                        SelectedItem="{Binding SelectedNamePreset, Mode=TwoWay}"
                                        IsVisible="{Binding !UseCustomName}"
                                        MinWidth="240" Width="240"
                                        Height="34"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center" />
                              <TextBox Classes="trackNameEditor"
                                       Text="{Binding CustomName, Mode=TwoWay}"
                                       IsVisible="{Binding UseCustomName}"
                                       MinWidth="240" Width="240"
                                       Height="34"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Center"
                                       Watermark="Type custom name" />
                            </Grid>
                          </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                      </DataGridTemplateColumn>
                      <DataGridTemplateColumn Header="Language" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                          <DataTemplate>
                            <ComboBox ItemsSource="{Binding LanguageOptions}" SelectedItem="{Binding EditedLanguage, Mode=TwoWay}" MinWidth="95" Width="95" />
                          </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                      </DataGridTemplateColumn>
                      <DataGridTextColumn Header="Current" Binding="{Binding CurrentSummary}" Width="520" IsReadOnly="True" />
                    </DataGrid.Columns>
                  </DataGrid>
                </Grid>
              </Border>

              <Border Grid.Row="2" Classes="panel" MinHeight="120">
                <Grid RowDefinitions="Auto,Auto,*">
                  <TextBlock Grid.Row="0" Text="Subtitle Tracks" Classes="section-header" />
                  <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8" VerticalAlignment="Center">
                    <TextBlock Text="Set default track" VerticalAlignment="Center" />
                    <ComboBox ItemsSource="{Binding DefaultSubtitleOptions}" SelectedItem="{Binding SelectedDefaultSubtitle}" Width="170" />
                  </StackPanel>
                  <DataGrid Grid.Row="2"
                            ItemsSource="{Binding PropEditSubtitleTracks}"
                            AutoGenerateColumns="False"
                            IsReadOnly="False"
                            ScrollViewer.VerticalScrollBarVisibility="Auto"
                            ScrollViewer.HorizontalScrollBarVisibility="Auto"
                            HorizontalAlignment="Stretch">
                    <DataGrid.Columns>
                      <DataGridTextColumn Header="Track" Binding="{Binding TrackLabel}" Width="110" IsReadOnly="True" />
                      <DataGridTemplateColumn Header="Custom" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                          <DataTemplate>
                            <CheckBox IsChecked="{Binding UseCustomName, Mode=TwoWay}"
                                      HorizontalAlignment="Left"
                                      VerticalAlignment="Center"
                                      Margin="8,0,0,0" />
                          </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                      </DataGridTemplateColumn>
                      <DataGridTemplateColumn Header="Name" Width="260">
                        <DataGridTemplateColumn.CellTemplate>
                          <DataTemplate>
                            <Grid>
                              <ComboBox Classes="trackNameEditor"
                                        ItemsSource="{Binding NameOptions}"
                                        SelectedItem="{Binding SelectedNamePreset, Mode=TwoWay}"
                                        IsVisible="{Binding !UseCustomName}"
                                        MinWidth="240" Width="240"
                                        Height="34"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center" />
                              <TextBox Classes="trackNameEditor"
                                       Text="{Binding CustomName, Mode=TwoWay}"
                                       IsVisible="{Binding UseCustomName}"
                                       MinWidth="240" Width="240"
                                       Height="34"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Center"
                                       Watermark="Type custom name" />
                            </Grid>
                          </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                      </DataGridTemplateColumn>
                      <DataGridTemplateColumn Header="Language" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                          <DataTemplate>
                            <ComboBox ItemsSource="{Binding LanguageOptions}" SelectedItem="{Binding EditedLanguage, Mode=TwoWay}" MinWidth="95" Width="95" />
                          </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                      </DataGridTemplateColumn>
                      <DataGridTextColumn Header="Current" Binding="{Binding CurrentSummary}" Width="520" IsReadOnly="True" />
                    </DataGrid.Columns>
                  </DataGrid>
                </Grid>
              </Border>
            </Grid>
          </Border>

          <Border Classes="card"
                  Grid.Row="1"
                  IsVisible="{Binding !IsPropEditSummaryExpanded}">
            <DockPanel>
              <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,6">
                <TextBlock Grid.Column="0" Text="Preview Summary" Classes="section-header" Margin="0" />
                <Button Grid.Column="1"
                        Content="Expand"
                        Width="72"
                        Height="28"
                        Padding="8,0"
                        FontSize="12"
                        Command="{Binding TogglePropEditSummaryExpandedCommand}" />
              </Grid>
              <ListBox ItemsSource="{Binding PlannedActions}"
                       Classes="console"
                       Margin="4">
                <ListBox.ItemTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding}"
                               FontFamily="Consolas"
                               FontSize="12"
                               LineHeight="13"
                               Margin="0,-2,0,-2" />
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </DockPanel>
          </Border>
          </Grid>

          <Border Grid.Row="0"
                  Grid.Column="0"
                  Grid.ColumnSpan="2"
                  Classes="card"
                  IsVisible="{Binding IsPropEditSummaryExpanded}">
            <DockPanel>
              <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                <TextBlock Grid.Column="0" Text="Preview Summary" Classes="section-header" Margin="0" />
                <Button Grid.Column="1"
                        Content="Collapse"
                        Width="82"
                        Height="28"
                        Padding="8,0"
                        FontSize="12"
                        Command="{Binding TogglePropEditSummaryExpandedCommand}" />
              </Grid>
              <ListBox ItemsSource="{Binding PlannedActions}"
                       Classes="console"
                       Margin="4">
                <ListBox.ItemTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding}"
                               FontFamily="Consolas"
                               FontSize="12"
                               LineHeight="13"
                               TextWrapping="Wrap"
                               Margin="0,-2,0,-2" />
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </DockPanel>
          </Border>

        </Grid>
</UserControl>
