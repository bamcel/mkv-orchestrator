<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MKVOrchestrator.App.ViewModels"
             x:Class="MKVOrchestrator.App.Views.Dashboard.DashboardPanel"
             x:DataType="vm:MainWindowViewModel">
        <Grid RowDefinitions="*,300" ColumnDefinitions="320,*,420" RowSpacing="12" ColumnSpacing="12" Margin="0,12,0,0"
              DragDrop.AllowDrop="True"
              DragDrop.DragOver="Dashboard_DragOver"
              DragDrop.Drop="Dashboard_Drop">

          <Border Classes="card" Grid.Row="0" Grid.Column="0">
            <DockPanel LastChildFill="True">
              <TextBlock DockPanel.Dock="Top" Text="Source Folder" Classes="section-header" />

              <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Spacing="4">
                  <TextBox Text="{Binding FolderPath}"
                           Watermark="Select folder(s) containing MKV or MP4 files"
                           Height="36"
                           MinHeight="36"
                           TextWrapping="NoWrap"
                           AcceptsReturn="False"
                           ToolTip.Tip="{Binding FolderPath}" />
                  <Grid ColumnDefinitions="*,*,*" ColumnSpacing="6" HorizontalAlignment="Stretch">
                    <Button Grid.Column="0"
                            Content="Browse"
                            MinWidth="84"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            Command="{Binding BrowseFolderCommand}"
                            CommandParameter="{Binding $parent[Window]}" />
                    <Button Grid.Column="1"
                            Content="Scan"
                            MinWidth="84"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            Command="{Binding ScanCommand}"
                            IsEnabled="{Binding !IsBusy}" />
                    <Button Grid.Column="2"
                            Content="Cancel"
                            MinWidth="84"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            Command="{Binding CancelCommand}"
                            IsEnabled="{Binding IsBusy}" />
                  </Grid>

                  <TextBlock Text="One folder name per line or comma-separated. Matching is not case-sensitive." TextWrapping="Wrap" Classes="muted" />
                  <TextBox Text="{Binding IgnoredScanFolderNameText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                           Watermark="Extras, OVAs, backdrops, Specials"
                           MinHeight="96"
                           TextWrapping="Wrap"
                           AcceptsReturn="True" />
                </StackPanel>
              </ScrollViewer>
            </DockPanel>
          </Border>

          <Border Classes="card" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2">
            <DockPanel>
              <Grid DockPanel.Dock="Top" ColumnDefinitions="Auto,*" Margin="0,0,0,10">
                <TextBlock Grid.Column="0" Text="File Info" Classes="section-header" />
                <Button Grid.Column="1"
                        Content="Use Selected as Template"
                        HorizontalAlignment="Right"
                        MinWidth="190"
                        Classes="dashboard-action-button"
                        Command="{Binding UseSelectedFileAsTemplateCommand}" />
              </Grid>
              <!-- v1_16 Dashboard File Info sorting: columns have explicit SortMemberPath. -->
              <Grid>
                <Border IsVisible="{Binding HasNoDashboardFiles}"
                        Background="{DynamicResource ThemeSidebarBackgroundBrush}"
                        BorderBrush="{DynamicResource ThemeBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="26"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch">
                  <StackPanel Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="No files scanned yet" Classes="empty-title" HorizontalAlignment="Center" />
                    <TextBlock Text="Drag folders here or click Scan" Classes="empty-subtitle" HorizontalAlignment="Center" />
                  </StackPanel>
                </Border>
<DataGrid x:Name="FileInfoGrid"
                        IsVisible="{Binding HasDashboardFiles}"
                        ItemsSource="{Binding Files}"
                        SelectedItem="{Binding SelectedFile}"
                        KeyDown="FileGrid_KeyDown"
                        AutoGenerateColumns="False"
                        Classes="file-info-grid"
                        Margin="2"
                        IsReadOnly="True"
                        SelectionMode="Extended"
                        CanUserResizeColumns="True"
                        CanUserSortColumns="True"
                        CanUserReorderColumns="True"
          HorizontalScrollBarVisibility="Auto"
          VerticalScrollBarVisibility="Auto">
                <DataGrid.Columns>
                  <DataGridTemplateColumn Header="File" Width="SizeToCells" MinWidth="260" CanUserResize="True" CanUserSort="True" SortMemberPath="FileName">
                    <DataGridTemplateColumn.CellTemplate>
                      <DataTemplate>
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" Margin="2,0,2,0">
                          <CheckBox Grid.Column="0"
                                    IsChecked="{Binding Selected, Mode=TwoWay}"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Margin="0"
                                    Focusable="False"
                                    Click="UseCheckBox_Click" />
                          <TextBlock Grid.Column="1"
                                     Text="{Binding FileName}"
                                     Foreground="{Binding RowVisualState, Converter={StaticResource VisualStateBrushConverter}}"
                                     TextWrapping="NoWrap"
                                     TextTrimming="CharacterEllipsis"
                                     ToolTip.Tip="{Binding FileName}" />
                        </Grid>
                      </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                  </DataGridTemplateColumn>
                  <DataGridTemplateColumn Header="Resolution" Width="110" MinWidth="90" CanUserResize="True" CanUserSort="True" SortMemberPath="Resolution">
                    <DataGridTemplateColumn.CellTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding Resolution}" Foreground="{Binding RowVisualState, Converter={StaticResource VisualStateBrushConverter}}" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding Resolution}" Margin="2,0,2,0" />
                      </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                  </DataGridTemplateColumn>
                  <DataGridTemplateColumn Header="Codec" Width="90" MinWidth="70" CanUserResize="True" CanUserSort="True" SortMemberPath="Codec">
                    <DataGridTemplateColumn.CellTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding Codec}" Foreground="{Binding RowVisualState, Converter={StaticResource VisualStateBrushConverter}}" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding Codec}" Margin="2,0,2,0" />
                      </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                  </DataGridTemplateColumn>
                  <DataGridTemplateColumn Header="Bit Depth" Width="90" MinWidth="75" CanUserResize="True" CanUserSort="True" SortMemberPath="BitDepth">
                    <DataGridTemplateColumn.CellTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding BitDepth}" Foreground="{Binding RowVisualState, Converter={StaticResource VisualStateBrushConverter}}" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding BitDepth}" Margin="2,0,2,0" />
                      </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                  </DataGridTemplateColumn>
                  <DataGridTemplateColumn Header="Audio" Width="140" MinWidth="95" CanUserResize="True" CanUserSort="True" SortMemberPath="AudioSummary">
                    <DataGridTemplateColumn.CellTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding AudioSummary}" Foreground="{Binding RowVisualState, Converter={StaticResource VisualStateBrushConverter}}" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding AudioSummary}" Margin="2,0,2,0" />
                      </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                  </DataGridTemplateColumn>
                  <DataGridTemplateColumn Header="Subs" Width="130" MinWidth="85" CanUserResize="True" CanUserSort="True" SortMemberPath="SubtitleSummary">
                    <DataGridTemplateColumn.CellTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding SubtitleSummary}" Foreground="{Binding RowVisualState, Converter={StaticResource VisualStateBrushConverter}}" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding SubtitleSummary}" Margin="2,0,2,0" />
                      </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                  </DataGridTemplateColumn>
                  <DataGridTemplateColumn Header="Status" Width="105" MinWidth="85" CanUserResize="True" CanUserSort="True" SortMemberPath="Status">
                    <DataGridTemplateColumn.CellTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding Status}" Foreground="{Binding RowVisualState, Converter={StaticResource VisualStateBrushConverter}}" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding Status}" Margin="2,0,2,0" />
                      </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                  </DataGridTemplateColumn>
                </DataGrid.Columns>
              </DataGrid>
              </Grid>
            </DockPanel>
          </Border>

          <Border Grid.ColumnSpan="2" Grid.Column="1" Classes="card" Grid.Row="1">
            <DockPanel LastChildFill="True">
              <TextBlock DockPanel.Dock="Top" Text="Media Info" Classes="section-header" />

              <!-- Media metadata and track details use side-by-side panels. Attachment summary stays inline within Metadata. -->
              <Grid ColumnDefinitions="0.95*,1.05*" ColumnSpacing="12" Margin="4">

                <Border Grid.Column="0" Classes="panel">
                  <DockPanel LastChildFill="True">
                    <TextBlock DockPanel.Dock="Top" Text="Metadata" Classes="section-header" />
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                      <Grid ColumnDefinitions="110,*"
                            RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                            RowSpacing="6"
                            ColumnSpacing="14">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Filename" Classes="muted" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedFile.FileName}" Foreground="{Binding SelectedFile.RowVisualState, Converter={StaticResource VisualStateBrushConverter}, ConverterParameter=TemplateOnly}" FontWeight="SemiBold" TextWrapping="Wrap" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Resolution" Classes="muted" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedFile.Resolution}" Foreground="{Binding SelectedFile.ResolutionVisualState, Converter={StaticResource VisualStateBrushConverter}}" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Codec" Classes="muted" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedFile.Codec}" Foreground="{Binding SelectedFile.CodecVisualState, Converter={StaticResource VisualStateBrushConverter}}" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Bit Depth" Classes="muted" />
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedFile.BitDepth}" Foreground="{Binding SelectedFile.BitDepthVisualState, Converter={StaticResource VisualStateBrushConverter}}" />

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Audio" Classes="muted" />
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SelectedFile.AudioSummary}" Foreground="{Binding SelectedFile.AudioSummaryVisualState, Converter={StaticResource VisualStateBrushConverter}}" TextWrapping="Wrap" />

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Subtitles" Classes="muted" />
                        <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding SelectedFile.SubtitleSummary}" Foreground="{Binding SelectedFile.SubtitleSummaryVisualState, Converter={StaticResource VisualStateBrushConverter}}" TextWrapping="Wrap" />

                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Attachments" Classes="muted" />
                        <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding SelectedFile.AttachmentSummary}" Foreground="{DynamicResource ThemeTextBrush}" TextWrapping="Wrap" />
                      </Grid>
                    </ScrollViewer>
                  </DockPanel>
                </Border>

                <Border Grid.Column="1" Classes="panel">
                  <DockPanel LastChildFill="True">
                    <TextBlock DockPanel.Dock="Top" Text="Track Info" Classes="section-header" />
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                      <ItemsControl ItemsSource="{Binding SelectedTracks}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <Border Classes="panel" Padding="8" Margin="0,0,0,8">
                              <Grid ColumnDefinitions="95,*"
                                    RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                                    RowSpacing="5"
                                    ColumnSpacing="12">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Track ID" Classes="muted" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding MkvMergeId}" Foreground="{Binding TrackNumberVisualState, Converter={StaticResource VisualStateBrushConverter}}" />

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Type" Classes="muted" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Type}" Foreground="{Binding TypeVisualState, Converter={StaticResource VisualStateBrushConverter}}" />

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Language" Classes="muted" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Language}" Foreground="{Binding LanguageVisualState, Converter={StaticResource VisualStateBrushConverter}}" />

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Codec" Classes="muted" />
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Codec}" Foreground="{Binding CodecVisualState, Converter={StaticResource VisualStateBrushConverter}}" TextWrapping="Wrap" />

                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Name" Classes="muted" />
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Name}" Foreground="{Binding NameVisualState, Converter={StaticResource VisualStateBrushConverter}}" TextWrapping="Wrap" />
                              </Grid>
                            </Border>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </ScrollViewer>
                  </DockPanel>
                </Border>

              </Grid>
            </DockPanel>
          </Border>

          <Border Grid.Column="0"
                  Classes="card"
                  Grid.Row="1"
                  IsVisible="{Binding !IsSummaryExpanded}">
            <DockPanel>
              <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,6">
                <TextBlock Grid.Column="0" Text="Summary" Classes="section-header" Margin="0" />
                <Button Grid.Column="1"
                        Content="Expand"
                        Width="72"
                        Height="28"
                        Padding="8,0"
                        FontSize="12"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Command="{Binding ToggleSummaryExpandedCommand}" />
              </Grid>
              <ListBox ItemsSource="{Binding DashboardConsoleLines}"
                       Classes="console"
                       Margin="4"
                       MinHeight="120">
                <ListBox.ItemTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding}"
                               FontFamily="Consolas"
                               FontSize="12"
                               LineHeight="13"
                               Margin="0,-2,0,-2" />
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </DockPanel>
          </Border>

          <Border Grid.Row="0"
                  Grid.RowSpan="2"
                  Grid.Column="0"
                  Grid.ColumnSpan="3"
                  Classes="card"
                  IsVisible="{Binding IsSummaryExpanded}"
                  Margin="0">
            <DockPanel>
              <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                <TextBlock Grid.Column="0" Text="Summary" Classes="section-header" Margin="0" />
                <Button Grid.Column="1"
                        Content="Collapse"
                        Width="82"
                        Height="28"
                        Padding="8,0"
                        FontSize="12"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Command="{Binding ToggleSummaryExpandedCommand}" />
              </Grid>
              <ListBox ItemsSource="{Binding DashboardConsoleLines}"
                       Classes="console"
                       Margin="4"
                       MinHeight="360">
                <ListBox.ItemTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding}"
                               FontFamily="Consolas"
                               FontSize="12"
                               LineHeight="13"
                               TextWrapping="Wrap"
                               Margin="0,-2,0,-2" />
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </DockPanel>
          </Border>
        </Grid>
</UserControl>
