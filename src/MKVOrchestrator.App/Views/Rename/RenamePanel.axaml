<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MKVOrchestrator.App.ViewModels"
             x:Class="MKVOrchestrator.App.Views.Rename.RenamePanel"
             x:DataType="vm:MainWindowViewModel">
        <Grid RowDefinitions="*" ColumnDefinitions="370,*" RowSpacing="12" ColumnSpacing="12" Margin="0,12,0,0">
          <Border Classes="card" Grid.Row="0" Grid.Column="0" Padding="8">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,*" RowSpacing="4">
              <DockPanel Grid.Row="0" LastChildFill="False">
                <TextBlock Text="Rename Options" Classes="section-header" />
              </DockPanel>

              <TextBlock Grid.Row="1"
                         Text="Search, select result, choose scope, pick naming template, then build preview."
                         TextWrapping="Wrap"
                         Classes="muted"
                         FontSize="11"
                         Margin="0,0,0,6" />

              <Border Grid.Row="2" Classes="console" Padding="8" MinHeight="30" HorizontalAlignment="Left" Width="330">
                <TextBlock Text="{Binding AppState.DashboardSelectionStatus}"
                           Classes="success"
                           FontSize="12"
                           TextWrapping="NoWrap"
                           TextTrimming="CharacterEllipsis" />
              </Border>

              <TextBlock Grid.Row="3" Text="Search Title" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource ThemeTextBrush}" Margin="0,5,0,1" />

              <Grid Grid.Row="4" ColumnDefinitions="*,120" ColumnSpacing="6" HorizontalAlignment="Left" Width="330">
                <StackPanel Grid.Column="0" Spacing="3">
                  <TextBox Text="{Binding RenameSearchTitle}"
                           Watermark="Example: Frieren Beyond Journey's End"
                           MinHeight="36"
                           Padding="10,0,8,0" />
                </StackPanel>
                <Button Grid.Column="1"
                        Content="Search DB"
                        Command="{Binding SearchTvdbCommand}"
                        IsEnabled="{Binding !IsBusy}"
                       
                        MinHeight="36"
                        VerticalAlignment="Bottom" />
              </Grid>

              <TextBlock Grid.Row="5" Text="Database Options" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource ThemeTextBrush}" Margin="0,5,0,1" />

              <Grid Grid.Row="6" ColumnDefinitions="*,*" ColumnSpacing="6" HorizontalAlignment="Left" Width="330">
                <StackPanel Grid.Column="0" Spacing="3">
                  <ComboBox ItemsSource="{Binding RenameLookupProviderOptions}"
                            SelectedItem="{Binding RenameLookupProvider}"
                            HorizontalAlignment="Stretch"
                            MinHeight="36" />
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="3">
                  <ComboBox ItemsSource="{Binding TvdbLanguageOptions}"
                            SelectedItem="{Binding TvdbLanguage}"
                            HorizontalAlignment="Stretch"
                            MinHeight="36" />
                </StackPanel>
              </Grid>

              <StackPanel Grid.Row="7" IsVisible="{Binding IsBusy}" Spacing="3">
                <ProgressBar IsIndeterminate="True" Height="5" />
                <TextBlock Text="{Binding RenameStatusText}" Classes="muted" FontSize="11" TextWrapping="Wrap" />
              </StackPanel>

              <TextBlock Grid.Row="8" Text="Series/Movie" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource ThemeTextBrush}" Margin="0,5,0,1" />

              <StackPanel Grid.Row="9" Spacing="3" HorizontalAlignment="Left" Width="330" MaxWidth="330">
                <ComboBox ItemsSource="{Binding TvdbSeriesResults}"
                          SelectedItem="{Binding SelectedTvdbSeries}"
                          HorizontalAlignment="Stretch"
                          MaxWidth="330"
                          MinHeight="36"
                          MaxDropDownHeight="360">
                  <ComboBox.ItemTemplate>
                    <DataTemplate>
                      <StackPanel MaxWidth="310" Spacing="1">
                        <TextBlock Text="{Binding Provider}" FontSize="10" Classes="success" />
                        <TextBlock Text="{Binding Overview}" FontSize="11" TextWrapping="Wrap" Classes="muted" MaxHeight="36" />
                      </StackPanel>
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
              </StackPanel>

              <TextBlock Grid.Row="10" Text="Episodes" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource ThemeTextBrush}" Margin="0,5,0,1" />

              <StackPanel Grid.Row="11" Spacing="3" HorizontalAlignment="Left" Width="330" MaxWidth="330">
                <Expander Classes="scope-dropdown"
                          HorizontalAlignment="Stretch"
                          MaxWidth="330"
                          MinHeight="36"
                          Background="{DynamicResource ThemeInputBackgroundBrush}"
                          BorderBrush="{DynamicResource ThemeButtonBackgroundBrush}"
                          BorderThickness="1"
                          CornerRadius="4">
                  <Expander.Header>
                    <Border Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="0"
                            CornerRadius="4"
                            Padding="8,5"
                            MinHeight="36"
                            HorizontalAlignment="Stretch">
                      <TextBlock Text="{Binding EpisodeScopeSummary}"
                                 TextWrapping="NoWrap"
                                 TextTrimming="CharacterEllipsis"
                                 VerticalAlignment="Center" />
                    </Border>
                  </Expander.Header>
                  <Border Background="{DynamicResource ThemeInputBackgroundBrush}"
                          BorderBrush="{DynamicResource ThemeButtonBackgroundBrush}"
                          BorderThickness="1"
                          CornerRadius="4"
                          Padding="5"
                          MaxHeight="180"
                          Margin="0,3,0,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                      <ItemsControl ItemsSource="{Binding TvdbSeasonScopeOptions}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <CheckBox Content="{Binding DisplayName}"
                                      IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                      Margin="0,1,0,1"
                                      HorizontalAlignment="Stretch" />
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </ScrollViewer>
                  </Border>
                </Expander>
              </StackPanel>

              <TextBlock Grid.Row="12" Text="Naming Template" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource ThemeTextBrush}" Margin="0,5,0,1" />

              <StackPanel Grid.Row="13" Spacing="3" HorizontalAlignment="Left" Width="330" MaxWidth="330">
                <ComboBox ItemsSource="{Binding RenameTemplateOptions}"
                          SelectedItem="{Binding SelectedRenameTemplateOption}"
                          HorizontalAlignment="Left"
                          Width="330"
                          MaxWidth="330"
                          MinHeight="36"
                          Padding="0">
                  <ComboBox.SelectionBoxItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding}"
                                 Margin="12,0,28,0"
                                 VerticalAlignment="Center"
                                 TextWrapping="NoWrap"
                                 TextTrimming="CharacterEllipsis" />
                    </DataTemplate>
                  </ComboBox.SelectionBoxItemTemplate>
                  <ComboBox.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding}"
                                 Width="300"
                                 Margin="8,0,8,0"
                                 TextWrapping="NoWrap"
                                 TextTrimming="CharacterEllipsis" />
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
                <TextBlock Text="{}Manage templates in Settings > Rename."
                           TextWrapping="Wrap"
                           Classes="muted"
                           FontSize="10" />
              </StackPanel>

              <TextBlock Grid.Row="14" Text="Execution" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource ThemeTextBrush}" Margin="0,5,0,1" />

              <StackPanel Grid.Row="15" Orientation="Horizontal" Spacing="6" Margin="0,6,0,0" HorizontalAlignment="Left">
                <Button Width="96"
                        Command="{Binding BuildRenamePreviewCommand}"
                        IsEnabled="{Binding !IsBusy}">
                  <TextBlock Text="Preview"
                             Foreground="{Binding PreviewButtonForeground}"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center" />
                </Button>
                <Button Content="Execute" Width="96" Command="{Binding ApplyRenamePreviewCommand}" />
              </StackPanel>

              <Border Grid.Row="16" Classes="console" Padding="8" MinHeight="58" HorizontalAlignment="Left" Width="330">
                <TextBlock Text="{Binding RenameStatusText}"
                           Classes="success"
                           TextWrapping="Wrap"
                           FontSize="12" />
              </Border>
            </Grid>
          </Border>

          <Grid Grid.Row="0" Grid.Column="1" RowDefinitions="*,190" RowSpacing="12">
          <Border Classes="card" Grid.Row="0">
            <DockPanel>
              <TextBlock DockPanel.Dock="Top" Text="Rename Preview" Classes="section-header" />
              <DataGrid ItemsSource="{Binding RenameItems}"
                        AutoGenerateColumns="False"
                        IsReadOnly="False"
                        CanUserResizeColumns="True"
                        CanUserSortColumns="True"
                        SelectionMode="Extended"
                        HorizontalScrollBarVisibility="Auto"
                        VerticalScrollBarVisibility="Auto">
                <DataGrid.Columns>
                  <DataGridTemplateColumn Header="Use" Width="70" MinWidth="60" CanUserSort="False">
                    <DataGridTemplateColumn.CellTemplate>
                      <DataTemplate>
                        <CheckBox IsChecked="{Binding Selected, Mode=TwoWay}" HorizontalAlignment="Left" />
                      </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                  </DataGridTemplateColumn>
                  <DataGridTextColumn Header="Current File" Binding="{Binding CurrentFileName}" Width="280" IsReadOnly="True" />
                  <DataGridTextColumn Header="Detected" Binding="{Binding DetectedEpisode}" Width="100" IsReadOnly="True" />
                  <DataGridTextColumn Header="Episode Name" Binding="{Binding MatchedEpisodeTitle}" Width="220" IsReadOnly="True" />
                  <DataGridTextColumn Header="New Filename" Binding="{Binding NewFileName}" Width="360" />
                  <DataGridTextColumn Header="Confidence" Binding="{Binding Confidence}" Width="110" IsReadOnly="True" />
                  <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="180" IsReadOnly="True" />
                </DataGrid.Columns>
              </DataGrid>
            </DockPanel>
          </Border>

          <Border Classes="card"
                  Grid.Row="1"
                  IsVisible="{Binding !IsRenameSummaryExpanded}">
            <DockPanel>
              <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,6">
                <TextBlock Grid.Column="0" Text="Preview Summary" Classes="section-header" Margin="0" />
                <Button Grid.Column="1"
                        Content="Expand"
                        Width="72"
                        Height="28"
                        Padding="8,0"
                        FontSize="12"
                        Command="{Binding ToggleRenameSummaryExpandedCommand}" />
              </Grid>
              <ListBox ItemsSource="{Binding RenameConsoleLines}"
                       Classes="console"
                       Margin="4">
                <ListBox.ItemTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding}"
                               FontFamily="Consolas"
                               FontSize="12"
                               LineHeight="13"
                               Margin="0,-2,0,-2" />
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </DockPanel>
          </Border>
          </Grid>

          <Border Grid.Row="0"
                  Grid.Column="0"
                  Grid.ColumnSpan="2"
                  Classes="card"
                  IsVisible="{Binding IsRenameSummaryExpanded}">
            <DockPanel>
              <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                <TextBlock Grid.Column="0" Text="Preview Summary" Classes="section-header" Margin="0" />
                <Button Grid.Column="1"
                        Content="Collapse"
                        Width="82"
                        Height="28"
                        Padding="8,0"
                        FontSize="12"
                        Command="{Binding ToggleRenameSummaryExpandedCommand}" />
              </Grid>
              <ListBox ItemsSource="{Binding RenameConsoleLines}"
                       Classes="console"
                       Margin="4">
                <ListBox.ItemTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding}"
                               FontFamily="Consolas"
                               FontSize="12"
                               LineHeight="13"
                               TextWrapping="Wrap"
                               Margin="0,-2,0,-2" />
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </DockPanel>
          </Border>

        </Grid>
</UserControl>
