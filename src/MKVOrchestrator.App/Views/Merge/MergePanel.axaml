<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MKVOrchestrator.App.ViewModels"
             x:Class="MKVOrchestrator.App.Views.Merge.MergePanel"
             x:DataType="vm:MainWindowViewModel">

  <UserControl.Styles>
    <Style Selector="TabControl.mergeCompactTabs TabItem">
      <Setter Property="FontSize" Value="13" />
      <Setter Property="Padding" Value="10,4" />
      <Setter Property="MinHeight" Value="30" />
    </Style>

    <Style Selector="TabControl.mergeCompactTabs TabItem:pointerover">
      <Setter Property="FontSize" Value="13" />
    </Style>

    <Style Selector="TabControl.mergeCompactTabs TabItem:selected">
      <Setter Property="FontSize" Value="13" />
      <Setter Property="Foreground" Value="#F8F8F2" />
    </Style>

    <Style Selector="TabControl.mergeCompactTabs TabItem:selected /template/ ContentPresenter">
      <Setter Property="Foreground" Value="#F8F8F2" />
    </Style>

    <Style Selector="TabControl.mergeCompactTabs TabItem:selected TextBlock">
      <Setter Property="Foreground" Value="#F8F8F2" />
    </Style>
  </UserControl.Styles>


<Grid RowDefinitions="*" ColumnDefinitions="370,*" RowSpacing="12" ColumnSpacing="12" Margin="0,12,0,0">
    <Border Classes="card" Grid.Row="0" Grid.Column="0" Padding="8">
      <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,*" RowSpacing="4">
        <TabControl Classes="mergeCompactTabs" Grid.Row="0"
                    Grid.RowSpan="14"
                    HorizontalAlignment="Left"
                    Width="330"
                    Margin="0">
          <TabItem Header="Remux">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
              <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,*" RowSpacing="4" Margin="0,4,0,0">

                <TextBlock Grid.Row="0" Text="Track Removal" FontSize="13" FontWeight="SemiBold" Foreground="#F8F8F2" Margin="0,5,0,1" />

                <StackPanel Grid.Row="1" Spacing="3" HorizontalAlignment="Left" Width="318">
                  <CheckBox Content="Remove unwanted audio languages"
                            IsChecked="{Binding MergeRemoveUnwantedAudioLanguages}" />
                  <TextBlock Text="Audio languages to keep"
                             Classes="muted"
                             FontSize="12"
                             Margin="10,0,0,-1" />
                  <Border Width="300"
                          HorizontalAlignment="Left"
                          Background="#282A36"
                          BorderBrush="#44475A"
                          BorderThickness="1"
                          CornerRadius="4"
                          ClipToBounds="False">
                    <TextBox BorderThickness="0" Background="Transparent" Text="{Binding MergeKeepAudioLanguages}"
                           Watermark="eng,jpn"
                           MinHeight="36"
                           Padding="10,0,8,0" />
                  </Border>
                </StackPanel>

                <StackPanel Grid.Row="2" Spacing="3" HorizontalAlignment="Left" Width="318" Margin="0,5,0,0">
                  <CheckBox Content="Remove unwanted subtitle languages"
                            IsChecked="{Binding MergeRemoveUnwantedSubtitleLanguages}" />
                  <TextBlock Text="Subtitle languages to keep"
                             Classes="muted"
                             FontSize="12"
                             Margin="10,0,0,-1" />
                  <Border Width="300"
                          HorizontalAlignment="Left"
                          Background="#282A36"
                          BorderBrush="#44475A"
                          BorderThickness="1"
                          CornerRadius="4"
                          ClipToBounds="False">
                    <TextBox BorderThickness="0" Background="Transparent" Text="{Binding MergeKeepSubtitleLanguages}"
                           Watermark="eng"
                           MinHeight="36"
                           Padding="10,0,8,0" />
                  </Border>
                </StackPanel>

                <StackPanel Grid.Row="3" Spacing="3" HorizontalAlignment="Left" Width="318" Margin="0,5,0,0">
                  <CheckBox Content="Remove unwanted track IDs"
                            IsChecked="{Binding MergeRemoveUnwantedTrackIds}" />
                  <Border Width="300"
                          HorizontalAlignment="Left"
                          Background="#282A36"
                          BorderBrush="#44475A"
                          BorderThickness="1"
                          CornerRadius="4"
                          ClipToBounds="False">
                    <TextBox BorderThickness="0" Background="Transparent" Text="{Binding MergeRemoveTrackIdsText}"
                           Watermark="1 or 1,3 or 1, 3"
                           MinHeight="36"
                           Padding="10,0,8,0" />
                  </Border>
                </StackPanel>

                <TextBlock Grid.Row="4" Text="Preservation Options" FontSize="13" FontWeight="SemiBold" Foreground="#F8F8F2" Margin="0,8,0,1" />

                <StackPanel Grid.Row="5" Spacing="3" HorizontalAlignment="Left" Width="318">
                  <CheckBox Content="Preserve chapters"
                            IsChecked="{Binding MergePreserveChapters}" />
                  <CheckBox Content="Preserve attachments/fonts"
                            IsChecked="{Binding MergePreserveAttachments}" />
                  <CheckBox Content="Use safe temp-file replacement"
                            IsChecked="{Binding MergeUseSafeTempReplacement}" />
                </StackPanel>

                <TextBlock Grid.Row="6" Text="Execution" FontSize="13" FontWeight="SemiBold" Foreground="#F8F8F2" Margin="0,8,0,1" />

                <StackPanel Grid.Row="7"
                            Orientation="Horizontal"
                            Spacing="6"
                            Margin="0,4,0,0"
                            HorizontalAlignment="Left">
                  <Button Content="Preview" Width="96" Command="{Binding BuildMkvMergePreviewCommand}" />
                  <Button Content="Execute" Width="96" Command="{Binding ExecuteMkvMergeCommand}" />
                </StackPanel>
              </Grid>
            </ScrollViewer>
          </TabItem>

          <TabItem Header="Subtitles">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
              <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,*" RowSpacing="4" Margin="0,4,0,0">

                <TextBlock Grid.Row="0" Text="Subtitle Mux" FontSize="13" FontWeight="SemiBold" Foreground="#F8F8F2" Margin="0,5,0,1" />

                <StackPanel Grid.Row="1" Spacing="3" HorizontalAlignment="Left" Width="318">
                  <CheckBox Content="Mux matching external subtitles"
                            IsChecked="{Binding MergeMuxMatchingExternalSubtitles}" />
                  <TextBlock Text="File Format: base_name.language.tag.ext"
                             Foreground="#BD93F9"
                             Margin="0,0,0,2" />
                  <TextBlock Text="Fallback language"
                             Classes="muted"
                             FontSize="12"
                             Margin="10,4,0,-1" />
                  <Border Width="300"
                          HorizontalAlignment="Left"
                          Background="#282A36"
                          BorderBrush="#44475A"
                          BorderThickness="1"
                          CornerRadius="4"
                          ClipToBounds="False">
                    <TextBox BorderThickness="0" Background="Transparent" Text="{Binding MergeExternalSubtitleLanguage}"
                           Watermark="eng"
                           MinHeight="36"
                           Padding="10,0,8,0" />
                  </Border>
                  <TextBlock Text="Subtitle file extensions"
                             Classes="muted"
                             FontSize="12"
                             Margin="10,4,0,-1" />
                  <Border Width="300"
                          HorizontalAlignment="Left"
                          Background="#282A36"
                          BorderBrush="#44475A"
                          BorderThickness="1"
                          CornerRadius="4"
                          ClipToBounds="False">
                    <TextBox BorderThickness="0" Background="Transparent" Text="{Binding MergeExternalSubtitleFormat}"
                           Watermark="srt,ass,ssa,sub,idx"
                           MinHeight="36"
                           Padding="10,0,8,0" />
                  </Border>
                  <TextBlock Text="Example: Episode 01.eng.Dialogue.ass. See more details on how to use in Settings."
                             TextWrapping="Wrap"
                             Classes="muted" />
                </StackPanel>

                <TextBlock Grid.Row="2" Text="Mux Options" FontSize="13" FontWeight="SemiBold" Foreground="#F8F8F2" Margin="0,8,0,1" />

                <StackPanel Grid.Row="3" Spacing="3" HorizontalAlignment="Left" Width="318">
                  <CheckBox Content="Preserve external subtitle files after mux"
                            IsChecked="{Binding MergePreserveExternalSubtitleFiles}" />
                  <CheckBox Content="Skip mux if subtitle track already exists"
                            IsChecked="{Binding MergeSkipMuxIfSubtitleAlreadyExists}" />
                </StackPanel>

                <TextBlock Grid.Row="4" Text="Subtitle Extract" FontSize="13" FontWeight="SemiBold" Foreground="#F8F8F2" Margin="0,8,0,1" />

                <StackPanel Grid.Row="5" Spacing="3" HorizontalAlignment="Left" Width="318">
                  <CheckBox Content="Extract embedded subtitles"
                            IsChecked="{Binding MergeExtractSubtitles}" />
                  <Border Width="300"
                          HorizontalAlignment="Left"
                          Background="#282A36"
                          BorderBrush="#44475A"
                          BorderThickness="1"
                          CornerRadius="4"
                          ClipToBounds="False">
                    <TextBox BorderThickness="0" Background="Transparent" Text="{Binding MergeExtractSubtitleLanguages}"
                           Watermark="eng or all"
                           MinHeight="36"
                           Padding="10,0,8,0" />
                  </Border>
                  <CheckBox Content="Overwrite existing subtitle files"
                            IsChecked="{Binding MergeExtractOverwriteExistingFiles}" />
                </StackPanel>

                <TextBlock Grid.Row="6" Text="Execution" FontSize="13" FontWeight="SemiBold" Foreground="#F8F8F2" Margin="0,8,0,1" />

                <StackPanel Grid.Row="7"
                            Orientation="Horizontal"
                            Spacing="6"
                            Margin="0,4,0,0"
                            HorizontalAlignment="Left">
                  <Button Content="Preview" Width="96" Command="{Binding BuildMkvMergePreviewCommand}" />
                  <Button Content="Execute" Width="96" Command="{Binding ExecuteMkvMergeCommand}" />
                </StackPanel>
              </Grid>
            </ScrollViewer>
          </TabItem>
        </TabControl>
      </Grid>
    </Border>

    <Grid Grid.Row="0" Grid.Column="1" RowDefinitions="1.3*,*,190" RowSpacing="12">
    <Border Classes="card" Grid.Row="0">
      <DockPanel>
        <TextBlock DockPanel.Dock="Top" Text="File Info" Classes="section-header" />
        <DataGrid x:Name="RemuxFilesGrid"
                  ItemsSource="{Binding Files}"
                  SelectedItem="{Binding SelectedFile}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  Margin="4"
                  SelectionMode="Extended"
                  CanUserResizeColumns="True"
                  CanUserSortColumns="True"
                  CanUserReorderColumns="False"
                  HorizontalScrollBarVisibility="Auto"
                  VerticalScrollBarVisibility="Auto"
                  KeyDown="FileGrid_KeyDown"
                  SelectionChanged="RemuxFilesGrid_SelectionChanged">
          <DataGrid.Columns>
            <DataGridTemplateColumn Width="82" MinWidth="82" MaxWidth="96" CanUserResize="True" CanUserSort="False">
              <DataGridTemplateColumn.Header>
                <TextBlock Text="Use"
                           HorizontalAlignment="Left"
                           TextAlignment="Left"
                           TextTrimming="None"
                           Margin="0" />
              </DataGridTemplateColumn.Header>
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <CheckBox IsChecked="{Binding Selected, Mode=TwoWay}"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Margin="0"
                            Focusable="False"
                            Click="UseCheckBox_Click" />
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <DataGridTemplateColumn Header="File" Width="*" MinWidth="260" CanUserResize="True" CanUserSort="True" SortMemberPath="FileName">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding FileName}"
                             Foreground="{Binding RowVisualState, Converter={StaticResource VisualStateBrushConverter}}"
                             TextWrapping="NoWrap"
                             TextTrimming="CharacterEllipsis"
                             ToolTip.Tip="{Binding FilePath}"
                             Margin="2,0,2,0" />
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <DataGridTemplateColumn Header="Audio" Width="130" MinWidth="105" CanUserResize="True" CanUserSort="True" SortMemberPath="AudioSummary">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding AudioSummary}"
                             Foreground="{Binding AudioSummaryVisualState, Converter={StaticResource VisualStateBrushConverter}}"
                             TextWrapping="NoWrap"
                             TextTrimming="CharacterEllipsis"
                             ToolTip.Tip="{Binding AudioSummary}"
                             Margin="2,0,2,0" />
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <DataGridTemplateColumn Header="Subtitles" Width="130" MinWidth="105" CanUserResize="True" CanUserSort="True" SortMemberPath="SubtitleSummary">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding SubtitleSummary}"
                             Foreground="{Binding SubtitleSummaryVisualState, Converter={StaticResource VisualStateBrushConverter}}"
                             TextWrapping="NoWrap"
                             TextTrimming="CharacterEllipsis"
                             ToolTip.Tip="{Binding SubtitleSummary}"
                             Margin="2,0,2,0" />
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
          </DataGrid.Columns>
        </DataGrid>
      </DockPanel>
    </Border>


    <Border Classes="card" Grid.Row="1">
      <DockPanel LastChildFill="True">
        <TabControl Classes="mergeCompactTabs" HorizontalContentAlignment="Stretch"
                    VerticalContentAlignment="Stretch"
                    Margin="0">
        <TabItem Header="File Details: Tracks">
          <DockPanel Margin="0">
            <DataGrid ItemsSource="{Binding SelectedTracks}" AutoGenerateColumns="False" IsReadOnly="True" Margin="0" CanUserResizeColumns="True">
          <DataGrid.Columns>
            <DataGridTemplateColumn Header="#" Width="45">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding MkvMergeId}"
                             Foreground="{Binding TrackNumberVisualState, Converter={StaticResource VisualStateBrushConverter}}" />
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <DataGridTemplateColumn Header="Type" Width="85">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Type}"
                             Foreground="{Binding TypeVisualState, Converter={StaticResource VisualStateBrushConverter}}" />
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <DataGridTemplateColumn Header="Lang" Width="65">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Language}"
                             Foreground="{Binding LanguageVisualState, Converter={StaticResource VisualStateBrushConverter}}" />
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <DataGridTemplateColumn Header="Codec" Width="180">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Codec}"
                             Foreground="{Binding CodecVisualState, Converter={StaticResource VisualStateBrushConverter}}"
                             TextTrimming="CharacterEllipsis"
                             ToolTip.Tip="{Binding Codec}" />
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <DataGridTemplateColumn Header="Name" Width="220">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Name}"
                             Foreground="{Binding NameVisualState, Converter={StaticResource VisualStateBrushConverter}}"
                             TextTrimming="CharacterEllipsis"
                             ToolTip.Tip="{Binding Name}" />
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
          </DataGrid.Columns>
        </DataGrid>
          </DockPanel>
        </TabItem>

        <TabItem Header="File Details: Attachments">
          <DockPanel Margin="0">
            <DataGrid ItemsSource="{Binding SelectedFile.Attachments, FallbackValue={x:Null}, TargetNullValue={x:Null}}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      Margin="0"
                      CanUserResizeColumns="True"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto">
              <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="55" />
                <DataGridTemplateColumn Header="File" Width="*" MinWidth="190">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding FileName}"
                                 TextWrapping="NoWrap"
                                 TextTrimming="CharacterEllipsis"
                                 ToolTip.Tip="{Binding FileName}" />
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Type" Width="150" MinWidth="110">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding ContentType}"
                                 TextWrapping="NoWrap"
                                 TextTrimming="CharacterEllipsis"
                                 ToolTip.Tip="{Binding ContentType}" />
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Size" Binding="{Binding SizeDisplay}" Width="95" />
              </DataGrid.Columns>
            </DataGrid>
          </DockPanel>
        </TabItem>
        </TabControl>
      </DockPanel>
    </Border>

    <Border Classes="card"
            Grid.Row="2"
            IsVisible="{Binding !IsMergeSummaryExpanded}">
      <DockPanel>
        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,6">
          <TextBlock Grid.Column="0" Text="Preview Summary" Classes="section-header" Margin="0" />
          <Button Grid.Column="1"
                  Content="Expand"
                  Width="72"
                  Height="28"
                  Padding="8,0"
                  FontSize="12"
                  Command="{Binding ToggleMergeSummaryExpandedCommand}" />
        </Grid>
        <ListBox ItemsSource="{Binding MkvMergePlanLines}"
                 Classes="console"
                 Margin="4">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding}"
                         FontFamily="Consolas"
                         FontSize="12"
                         LineHeight="13"
                         Margin="0,-2,0,-2" />
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </DockPanel>
    </Border>
    </Grid>

    <Border Grid.Row="0"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Classes="card"
            IsVisible="{Binding IsMergeSummaryExpanded}">
      <DockPanel>
        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,8">
          <TextBlock Grid.Column="0" Text="Preview Summary" Classes="section-header" Margin="0" />
          <Button Grid.Column="1"
                  Content="Collapse"
                  Width="82"
                  Height="28"
                  Padding="8,0"
                  FontSize="12"
                  Command="{Binding ToggleMergeSummaryExpandedCommand}" />
        </Grid>
        <ListBox ItemsSource="{Binding MkvMergePlanLines}"
                 Classes="console"
                 Margin="4">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding}"
                         FontFamily="Consolas"
                         FontSize="12"
                         LineHeight="13"
                         TextWrapping="Wrap"
                         Margin="0,-2,0,-2" />
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </DockPanel>
    </Border>
  </Grid>
</UserControl>
