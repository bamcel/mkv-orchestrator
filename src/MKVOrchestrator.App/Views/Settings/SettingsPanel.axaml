<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MKVOrchestrator.App.ViewModels"
             x:Class="MKVOrchestrator.App.Views.Settings.SettingsPanel"
             x:DataType="vm:MainWindowViewModel">
        <Grid RowDefinitions="*" RowSpacing="12" Margin="0,12,0,0">

          <Border Classes="card" Grid.Row="0">
            <DockPanel LastChildFill="True">
          <TextBlock DockPanel.Dock="Top" Text="Settings" Classes="section-header" />

              <TabControl Classes="settings-tabs">
<TabItem Header="General">
                  <ScrollViewer Margin="4">
                    <StackPanel Spacing="10" Margin="4">
                      <Border Classes="panel">
                        <DockPanel LastChildFill="True">
                          <TextBlock DockPanel.Dock="Top" Text="Application Startup" Classes="section-header" />
                          <StackPanel Spacing="8">
                            <TextBlock Text="Choose whether Dashboard opens at the configured default root folder or resumes from the last source folder used for browsing/scanning." TextWrapping="Wrap" Classes="muted" />
                            <Grid ColumnDefinitions="190,*" RowDefinitions="Auto,Auto" RowSpacing="8" ColumnSpacing="8">
                              <TextBlock Grid.Row="0" Grid.Column="0" Text="Source folder mode" VerticalAlignment="Center" />
                              <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding SourceFolderStartModeOptions}" SelectedItem="{Binding SourceFolderStartMode}" MaxWidth="260" HorizontalAlignment="Left" />

                              <TextBlock Grid.Row="1" Grid.Column="0" Text="Default root folder" VerticalAlignment="Center" />
                              <Grid Grid.Row="1" Grid.Column="1" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <TextBox Grid.Column="0" Text="{Binding RootFolderPath}" Watermark="Root folder used at startup" />
                                <Button Grid.Column="1" Content="Browse" Command="{Binding BrowseRootFolderCommand}" CommandParameter="{Binding $parent[Window]}" />
                              </Grid>
                            </Grid>
                          </StackPanel>
                        </DockPanel>
                      </Border>

                      <TextBlock Text="Select the MKVToolNix install folder. The app will use mkvmerge, mkvpropedit, mkvextract, and mkvinfo from this folder, with PATH fallback when blank or missing." TextWrapping="Wrap" Classes="muted" />
                      <Border Classes="panel">
                        <DockPanel LastChildFill="True">
                      <TextBlock DockPanel.Dock="Top" Text="MKVToolNix Paths" Classes="section-header" />
                      <Grid ColumnDefinitions="170,*,Auto,Auto" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="8" ColumnSpacing="8">
                          <TextBlock Grid.Row="0" Grid.Column="0" Text="MKVToolNix folder" VerticalAlignment="Center" />
                          <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding MkvToolNixDirectory}" Watermark="full path to MKVToolNix" />
                          <Button Grid.Row="0" Grid.Column="2" Content="Browse" Command="{Binding BrowseMkvToolNixDirectoryCommand}" CommandParameter="{Binding $parent[Window]}" />
                          <Button Grid.Row="0" Grid.Column="3" Content="Auto Find" Command="{Binding AutoFindMkvToolNixDirectoryCommand}" />

                          <TextBlock Grid.Row="1" Grid.Column="0" Text="Resolved tools" VerticalAlignment="Top" />
                          <TextBlock Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3"
                                     Text="{Binding MkvMergePath, StringFormat='mkvmerge: {0}'}"
                                     TextWrapping="NoWrap"
                                     TextTrimming="CharacterEllipsis"
                                     Classes="muted" />

                          <TextBlock Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3"
                                     Text="{Binding MkvPropEditPath, StringFormat='mkvpropedit: {0}'}"
                                     TextWrapping="NoWrap"
                                     TextTrimming="CharacterEllipsis"
                                     Classes="muted" />

                          <TextBlock Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="3"
                                     Text="{Binding MkvExtractPath, StringFormat='mkvextract: {0}'}"
                                     TextWrapping="NoWrap"
                                     TextTrimming="CharacterEllipsis"
                                     Classes="muted" />

                          <TextBlock Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="3"
                                     Text="{Binding MkvInfoPath, StringFormat='mkvinfo: {0}'}"
                                     TextWrapping="NoWrap"
                                     TextTrimming="CharacterEllipsis"
                                     Classes="muted" />

                          <TextBlock Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="3"
                                     Text="{Binding MkvToolNixAutoFindStatusText}"
                                     TextWrapping="Wrap"
                                     Classes="muted" />
                        </Grid>
                    </DockPanel>
                  </Border>

                      <TextBlock Text="FFmpeg is optional for MKV-only workflows and can remain empty when ffmpeg/ffprobe are available on PATH." TextWrapping="Wrap" Classes="muted" />
                      <Border Classes="panel">
                        <DockPanel LastChildFill="True">
                      <TextBlock DockPanel.Dock="Top" Text="FFmpeg Directory" Classes="section-header" />
                      <Grid ColumnDefinitions="170,*,Auto,Auto" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="8" ColumnSpacing="8">
                          <TextBlock Grid.Row="0" Grid.Column="0" Text="FFmpeg folder" VerticalAlignment="Center" />
                          <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding FfmpegDirectory}" Watermark="full path to FFmpeg bin folder" />
                          <Button Grid.Row="0" Grid.Column="2" Content="Browse" Command="{Binding BrowseFfmpegDirectoryCommand}" CommandParameter="{Binding $parent[Window]}" />
                          <Button Grid.Row="0" Grid.Column="3" Content="Auto Find" Command="{Binding AutoFindFfmpegDirectoryCommand}" />

                          <TextBlock Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3"
                                     Text="{Binding FfmpegPath, StringFormat='ffmpeg: {0}'}"
                                     TextWrapping="NoWrap"
                                     TextTrimming="CharacterEllipsis"
                                     Classes="muted" />

                          <TextBlock Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3"
                                     Text="{Binding FfProbePath, StringFormat='ffprobe: {0}'}"
                                     TextWrapping="NoWrap"
                                     TextTrimming="CharacterEllipsis"
                                     Classes="muted" />

                          <TextBlock Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="3"
                                     Text="{Binding FfmpegAutoFindStatusText}"
                                     TextWrapping="Wrap"
                                     Classes="muted" />
                        </Grid>
                    </DockPanel>
                  </Border>

                      <TextBlock Text="Settings are saved automatically to %APPDATA%\MKVOrchestrator\settings.json." TextWrapping="Wrap" Classes="muted" />
                    </StackPanel>
                  </ScrollViewer>
                </TabItem>

<TabItem Header="Theme">
                  <ScrollViewer Margin="4">
                    <StackPanel Spacing="10" Margin="4">
                      <TextBlock Text="Choose a built-in theme, edit the theme JSON, save custom variants, then reload to refresh the GUI. Built-in themes are read-only starting points." TextWrapping="Wrap" Classes="muted" />

                      <Border Classes="panel">
                        <StackPanel Spacing="10">
                          <TextBlock Text="Theme Selection" Classes="section-header" />
                          <Grid ColumnDefinitions="160,260,140,*" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="8">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Theme" VerticalAlignment="Center" />
                            <ComboBox Grid.Row="0" Grid.Column="1"
                                      ItemsSource="{Binding ThemeOptions}"
                                      SelectedItem="{Binding SelectedThemeName}"
                                      MinWidth="240" />
                            <Button Grid.Row="0" Grid.Column="2" Content="Reload Theme" Command="{Binding ReloadThemeCommand}" />
                            <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding ThemeStatusText}" TextWrapping="Wrap" Classes="muted" VerticalAlignment="Center" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Custom name" VerticalAlignment="Center" />
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding CustomThemeName, UpdateSourceTrigger=PropertyChanged}" Watermark="My Theme" />
                            <StackPanel Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="8">
                              <Button Content="Save Custom Theme" Command="{Binding SaveCustomThemeCommand}" />
                              <Button Content="Remove Custom Theme" Command="{Binding RemoveCustomThemeCommand}" />
                            </StackPanel>
                          </Grid>
                        </StackPanel>
                      </Border>

                      <Border Classes="panel">
                        <DockPanel>
                          <TextBlock DockPanel.Dock="Top" Text="Theme File" Classes="section-header" />
                          <TextBox Classes="settingsConsoleBox"
                                   Text="{Binding ThemeEditorText, UpdateSourceTrigger=PropertyChanged}"
                                   AcceptsReturn="True"
                                   Height="430"
                                   VerticalContentAlignment="Top"
                                   TextWrapping="NoWrap"
                                   FontFamily="Consolas"
                                   Watermark="{}{ &quot;Name&quot;: &quot;My Theme&quot;, &quot;Colors&quot;: { ... } }" />
                        </DockPanel>
                      </Border>
                    </StackPanel>
                  </ScrollViewer>
                </TabItem>

<TabItem Header="API Providers">
                  <ScrollViewer Margin="4">
                    <StackPanel Spacing="10" Margin="4">
                      <TextBlock Text="Each user should provide their own API credentials. Keys are stored locally in settings and are not written to logs or shared by MKVO." TextWrapping="Wrap" Classes="muted" />

                      <Border Classes="panel">
                        <DockPanel LastChildFill="True">
                      <TextBlock DockPanel.Dock="Top" Text="Provider Selection" Classes="section-header" />
                      <Grid ColumnDefinitions="190,*" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="8" ColumnSpacing="8">
                          <TextBlock Grid.Row="0" Grid.Column="0" Text="Default provider" VerticalAlignment="Center" />
                          <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding RenameLookupProviderOptions}" SelectedItem="{Binding RenameLookupProvider}" MaxWidth="260" HorizontalAlignment="Left" />

                          <TextBlock Grid.Row="1" Grid.Column="0" Text="Connection status" VerticalAlignment="Center" />
                          <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ApiProviderStatusText}" TextWrapping="Wrap" Classes="muted" />

                          <TextBlock Grid.Row="2" Grid.Column="0" Text="Selected configured" VerticalAlignment="Center" />
                          <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding IsSelectedRenameProviderConfigured}" Classes="muted" />

                          <Button Grid.Row="3" Grid.Column="1"
                                  Content="Test Selected Provider"
                                  Command="{Binding TestApiProviderConnectionCommand}"
                                  IsEnabled="{Binding !IsBusy}"
                                  HorizontalAlignment="Left" />
                        </Grid>
                    </DockPanel>
                  </Border>

                      <Grid ColumnDefinitions="*,*" RowDefinitions="Auto" ColumnSpacing="12" RowSpacing="12">
                        <Border Grid.Row="0" Grid.Column="0" Classes="panel">
                          <StackPanel Spacing="8">
                            <TextBlock Text="TVDB Credentials" Classes="section-header" />
                          <TextBlock Text="Used for official TVDB series, season, special, and episode-title lookup." TextWrapping="Wrap" Classes="muted" FontSize="12" />
                            <TextBlock Text="TVDB API key" />
                            <TextBox Text="{Binding TvdbApiKey}" Watermark="User-provided TVDB API key" PasswordChar="*" />
                            <TextBlock Text="TVDB PIN" />
                            <TextBox Text="{Binding TvdbPin}" Watermark="Optional TVDB subscriber PIN" PasswordChar="*" />
                            <TextBlock Text="Setup: https://www.thetvdb.com/api-information" TextWrapping="Wrap" Classes="muted" FontSize="11" />
                          </StackPanel>
                        </Border>

                        <Border Grid.Row="0" Grid.Column="1" Classes="panel">
                          <StackPanel Spacing="8">
                            <TextBlock Text="TMDB Credentials" Classes="section-header" />
                          <TextBlock Text="Used for TMDB TV search and season/episode lookup." TextWrapping="Wrap" Classes="muted" FontSize="12" />
                            <TextBlock Text="TMDB API key" />
                            <TextBox Text="{Binding TmdbApiKey}" Watermark="User-provided TMDB API key" PasswordChar="*" />
                            <TextBlock Text="Setup: https://developer.themoviedb.org/" TextWrapping="Wrap" Classes="muted" FontSize="11" />
                          </StackPanel>
                        </Border>
                      </Grid>

                      <Border Classes="panel">
                        <StackPanel Spacing="4">
                          <TextBlock Text="Credential Safety" Classes="section-header" />
                      <TextBlock Text="MKVO requires users to supply their own provider credentials. This avoids hardcoded shared keys, reduces rate-limit and abuse risk, and keeps provider access tied to the individual user." TextWrapping="Wrap" Classes="muted" />
                          <TextBlock Text="Do not paste API keys into logs, screenshots, support bundles, or public issue reports." TextWrapping="Wrap" Classes="muted" />
                        </StackPanel>
                      </Border>
                    </StackPanel>
                  </ScrollViewer>
                </TabItem>

<TabItem Header="Rename">
                  <ScrollViewer Margin="4">
                    <StackPanel Spacing="10" Margin="4">
                      <TextBlock Text="mkvrename loads dashboard files, searches the selected provider, populates relevant seasons/specials, matches local SxxExx values to provider episodes, previews generated names, then only renames rows the user approves." TextWrapping="Wrap" Classes="muted" />

                      <Border Classes="panel" Padding="16">
                        <StackPanel Spacing="16">

                          <TextBlock Text="Rename Templates" Classes="section-header" />
                    <Border Background="{DynamicResource ThemePanelBackgroundBrush}" BorderBrush="{DynamicResource ThemeBorderStrongBrush}" BorderThickness="1" CornerRadius="8" Padding="14">
                            <StackPanel Spacing="12">
                              <StackPanel Spacing="2">
                                <TextBlock Text="Template Management" Classes="section-header" />
                          <TextBlock Text="Configure rename templates and naming behavior for MKVRename." Classes="muted" />
                              </StackPanel>

                              <Grid ColumnDefinitions="170,*" RowDefinitions="Auto,Auto" RowSpacing="10" ColumnSpacing="10">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Template Profile" VerticalAlignment="Center" />
                                <ComboBox Grid.Row="0" Grid.Column="1"
                                          ItemsSource="{Binding RenameTemplateOptions}"
                                          SelectedItem="{Binding SelectedRenameTemplateOption}"
                                          MinWidth="540"
                                          HorizontalAlignment="Left" />

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Template Editor" VerticalAlignment="Center" />
                                <TextBox Grid.Row="1" Grid.Column="1"
                                         Text="{Binding RenameTemplate}"
                                         MinWidth="540"
                                         HorizontalAlignment="Left"
                                         Background="{DynamicResource ThemeInputBackgroundBrush}"
                                         Watermark="{}{series} - S{season:00}E{episode:00} - {episodeTitle}" />
                              </Grid>

                              <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Content="Save Template" Command="{Binding SaveRenameTemplateCommand}" />
                                <Button Content="Remove" Command="{Binding RemoveRenameTemplateCommand}" />
                                <Button Content="Restore Defaults" Command="{Binding RestoreDefaultRenameTemplatesCommand}" />
                              </StackPanel>
                            </StackPanel>
                          </Border>

                          <Border Background="{DynamicResource ThemePanelBackgroundBrush}" BorderBrush="{DynamicResource ThemeBorderStrongBrush}" BorderThickness="1" CornerRadius="8" Padding="14">
                            <StackPanel Spacing="12">
                              <StackPanel Spacing="2">
                                <TextBlock Text="Select the preferred provider used for rename lookups and metadata matching." Classes="muted" />
                              </StackPanel>

                              <Grid ColumnDefinitions="170,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="10" ColumnSpacing="10">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Default Lookup DB" VerticalAlignment="Center" />
                                <ComboBox Grid.Row="0" Grid.Column="1"
                                          ItemsSource="{Binding RenameLookupProviderOptions}"
                                          SelectedItem="{Binding RenameLookupProvider}"
                                          MaxWidth="260"
                                          HorizontalAlignment="Left" />

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Metadata Language" VerticalAlignment="Center" />
                                <ComboBox Grid.Row="1" Grid.Column="1"
                                          ItemsSource="{Binding TvdbLanguageOptions}"
                                          SelectedItem="{Binding TvdbLanguage}"
                                          MaxWidth="260"
                                          HorizontalAlignment="Left" />

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Provider Status" VerticalAlignment="Top" />
                                <TextBlock Grid.Row="2" Grid.Column="1"
                                           Text="{Binding ApiProviderStatusText}"
                                           TextWrapping="Wrap"
                                           Classes="muted" />
                              </Grid>
                            </StackPanel>
                          </Border>

                          <Border Background="{DynamicResource ThemePanelBackgroundBrush}" BorderBrush="{DynamicResource ThemeBorderStrongBrush}" BorderThickness="1" CornerRadius="8" Padding="14">
                            <StackPanel Spacing="10">

                              <WrapPanel Orientation="Horizontal" ItemWidth="240">
                                <TextBlock Text="{}{series}   → Series Name" Classes="muted" Margin="0,0,0,6" />
                                <TextBlock Text="{}{season}   → Season Number" Classes="muted" Margin="0,0,0,6" />
                                <TextBlock Text="{}{episode} → Episode Number" Classes="muted" Margin="0,0,0,6" />
                                <TextBlock Text="{}{episodeTitle} → Episode Title" Classes="muted" Margin="0,0,0,6" />
                                <TextBlock Text="{}{year}      → Release Year" Classes="muted" Margin="0,0,0,6" />
                                <TextBlock Text="{}{absolute} → Absolute Episode" Classes="muted" Margin="0,0,0,6" />
                              </WrapPanel>

                              <Border Background="{DynamicResource ThemeInputBackgroundBrush}" BorderBrush="{DynamicResource ThemeBorderStrongBrush}" BorderThickness="1" CornerRadius="6" Padding="10">
                                <StackPanel Spacing="4">
                                  <TextBlock Text="{}{season:00}  → 01" Classes="muted" />
                                  <TextBlock Text="{}{episode:000} → 001" Classes="muted" />
                                  <TextBlock Text="{}{series} - S{season:00}E{episode:00} - {episodeTitle}" Classes="muted" TextWrapping="Wrap" />
                                </StackPanel>
                              </Border>
                            </StackPanel>
                          </Border>
                        </StackPanel>
                      </Border>

                      <TextBlock Text="API credentials are configured under Settings > API Providers. MKVO does not ship shared production provider API keys." TextWrapping="Wrap" Classes="muted" />
                    </StackPanel>
                  </ScrollViewer>
                </TabItem>

<TabItem Header="Mux / Remux">
                  <ScrollViewer Margin="4">
                    <StackPanel Spacing="10" Margin="4">
                      <TextBlock Text="mkvmerge is used for MKV structure, track IDs, languages, names, and edit planning. ffprobe is used as a lightweight fallback for dashboard video metadata such as codec, resolution, and bit depth. Tool paths are configured under general." TextWrapping="Wrap" Classes="muted" />
                      <TextBlock Text="Scans run in parallel for speed, then dashboard results are naturally sorted by season/episode and filename before display." TextWrapping="Wrap" Classes="muted" />

                      <TextBlock Text="These defaults populate the editable keep-language boxes in the Mux / Remux tab. You can still override them there for one-off/special-case remux jobs." TextWrapping="Wrap" Classes="muted" />
                      <Border Classes="panel">
                        <DockPanel LastChildFill="True">
                      <TextBlock DockPanel.Dock="Top" Text="Mux / Remux Defaults" Classes="section-header" />
                      <Grid ColumnDefinitions="210,*" RowDefinitions="Auto,Auto" RowSpacing="8" ColumnSpacing="8">
                          <TextBlock Grid.Row="0" Grid.Column="0" Text="Default audio keep languages" VerticalAlignment="Center" />
                          <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding MkvMergeDefaultAudioLanguages}" Watermark="eng,jpn" />

                          <TextBlock Grid.Row="1" Grid.Column="0" Text="Default subtitle keep languages" VerticalAlignment="Center" />
                          <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding MkvMergeDefaultSubtitleLanguages}" Watermark="eng" />
                        </Grid>
                    </DockPanel>
                  </Border>

                      <Border Classes="panel">
                        <StackPanel Spacing="8">
                          <TextBlock Text="Subtitle Mux Usage" Classes="section-header" />
                          <TextBlock Text="File Format: base_name.language.tag.ext"
                                     Foreground="{DynamicResource ThemeAccentBrush}"
                                     FontSize="13"
                                     FontWeight="SemiBold" />
                          <TextBlock Text="Place external subtitle files in the same folder as the MKV. The base_name must match the MKV filename without .mkv. The language segment sets the muxed subtitle language, and the tag segment becomes the subtitle track name." TextWrapping="Wrap" Classes="muted" />

                          <Grid ColumnDefinitions="160,*" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="6" ColumnSpacing="10">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="MKV file" Classes="muted" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="Episode 01.mkv" FontFamily="Consolas" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Signs and songs" Classes="muted" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="Episode 01.eng.Signs &amp; Songs.ass" FontFamily="Consolas" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Dialogue" Classes="muted" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="Episode 01.eng.Dialogue.ass" FontFamily="Consolas" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Japanese track" Classes="muted" />
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="Episode 01.jpn.Dialogue.ass" FontFamily="Consolas" />
                          </Grid>

                          <TextBlock Text="Supported extension filters are configured in the Subtitles tab, for example srt, ass, ssa, sub, idx. If a sidecar has no language segment, the fallback language field is used." TextWrapping="Wrap" Classes="muted" />
                        </StackPanel>
                      </Border>
                    </StackPanel>
                  </ScrollViewer>
                </TabItem>

<TabItem Header="Properties">
                  <ScrollViewer Margin="4">
                    <StackPanel Spacing="10" Margin="4">
                      <TextBlock Text="Tool paths are configured under general." TextWrapping="Wrap" Classes="muted" />
                      <TextBlock Text="Edit these lists to control quick-select values used in the mkvpropedit audio/subtitle tables. Use one value per line, or separate values with commas/semicolons." TextWrapping="Wrap" Classes="muted" />

                      <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">
                        <Border Grid.Column="0" Classes="panel">
                          <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="Audio Name Presets" Classes="section-header" />
                        <TextBox Classes="settingsConsoleBox" Text="{Binding AudioNamePresetText}" AcceptsReturn="True" Height="210" VerticalContentAlignment="Top" TextWrapping="Wrap" Watermark="English&#x0a;Japanese&#x0a;Commentary" />
                          </DockPanel>
                        </Border>

                        <Border Grid.Column="1" Classes="panel">
                          <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="Subtitle Name Presets" Classes="section-header" />
                        <TextBox Classes="settingsConsoleBox" Text="{Binding SubtitleNamePresetText}" AcceptsReturn="True" Height="210" VerticalContentAlignment="Top" TextWrapping="Wrap" Watermark="English&#x0a;English Forced&#x0a;Signs &amp; Songs" />
                          </DockPanel>
                        </Border>

                        <Border Grid.Column="2" Classes="panel">
                          <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="Language Presets" Classes="section-header" />
                        <TextBox Classes="settingsConsoleBox" Text="{Binding LanguagePresetText}" AcceptsReturn="True" Height="210" VerticalContentAlignment="Top" TextWrapping="Wrap" Watermark="eng&#x0a;jpn&#x0a;und&#x0a;en&#x0a;ja" />
                          </DockPanel>
                        </Border>
                      </Grid>

                      <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                        <Button Content="Save preset lists" Command="{Binding SavePresetListsCommand}" />
                        <Button Content="Reset preset lists" Command="{Binding ResetPresetListsCommand}" />
                      </StackPanel>
                    </StackPanel>
                  </ScrollViewer>
                </TabItem>

<TabItem Header="Library">
                  <ScrollViewer Margin="4">
                    <StackPanel Spacing="10" Margin="4">
                      <TextBlock Text="The cache stores full dashboard media info and track info after a successful mkvmerge scan. Cached rows are only used when file size and modified time still match." TextWrapping="Wrap" Classes="muted" />
                      <Border Classes="panel">
                        <StackPanel Spacing="8">
                          <TextBlock Text="Cache Status" Classes="section-header" />
                          <Grid ColumnDefinitions="150,*" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="6" ColumnSpacing="10">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Watch entries" Classes="muted" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CacheWatchEntryCountText}" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Temp entries" Classes="muted" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CacheTempEntryCountText}" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Database size" Classes="muted" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding CacheDatabaseSizeText}" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Last cleanup" Classes="muted" />
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding CacheLastCleanupText}" TextWrapping="Wrap" />
                          </Grid>
                        </StackPanel>
                      </Border>
                      <Border Classes="panel">
                        <StackPanel Spacing="8">
                          <TextBlock Text="Watch Folders" Classes="section-header" />
                      <TextBlock Text="Enter one root folder per line. For a root like /anime, the cache builder recursively scans nested layouts such as /anime/anime_series/show/season01/show.mkv and /anime/anime_movies/movie/movie.mkv." TextWrapping="Wrap" Classes="muted" />
                          <TextBox Classes="settingsConsoleBox" Text="{Binding WatchFolderText}" AcceptsReturn="True" Height="120" VerticalContentAlignment="Top" TextWrapping="Wrap" Watermark="user/path/movies, user/path/tv, //server_name/share/tv" />
                          <CheckBox Content="Enable live watch folder monitoring" IsChecked="{Binding EnableLiveWatchFolderMonitoring}" />
                          <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="Build Library Cache" Command="{Binding BuildCacheFromWatchFoldersCommand}" />
                            <Button Content="Cancel Build" Command="{Binding CancelCommand}" IsEnabled="{Binding IsCacheBusy}" />
                            <Button Content="Clear Library Cache" Command="{Binding ClearMetadataCacheCommand}" />
                            <Button Content="Clear Temporary Cache" Command="{Binding ClearTempMetadataCacheCommand}" />
                            <Button Content="Restart Watcher" Command="{Binding RestartMetadataWatchersCommand}" />
                          </StackPanel>
                          <ProgressBar IsIndeterminate="{Binding IsCacheBusy}" Height="8" />
                          <TextBlock Text="{Binding CacheStatusText}" TextWrapping="Wrap" Classes="muted" />
                        </StackPanel>
                      </Border>
                    </StackPanel>
                  </ScrollViewer>
                </TabItem>

<TabItem Header="About">
                  <ScrollViewer Margin="4">
                    <StackPanel Spacing="12" Margin="4">
                      <Border Classes="panel">
                        <StackPanel Spacing="8">
                          <TextBlock Text="MKV Orchestrator" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource ThemeTextBrush}" />
                          <TextBlock Text="A desktop workflow tool for scanning media folders, reviewing track metadata, planning safe filename changes, and running MKV-focused maintenance tasks with preview-first execution."
                                     TextWrapping="Wrap"
                                     Classes="muted" />
                        </StackPanel>
                      </Border>

                      <Border Classes="panel">
                        <StackPanel Spacing="8">
                          <TextBlock Text="Format Support" Classes="section-header" />
                          <Grid ColumnDefinitions="92,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="8" ColumnSpacing="12">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="MKV" FontWeight="SemiBold" Foreground="{DynamicResource ThemeAccentBrush}" />
                            <TextBlock Grid.Row="0" Grid.Column="1"
                                       Text="Full application workflow support: scan, inspect, rename planning, remux planning, subtitle mux/extract planning, and track property editing through MKVToolNix."
                                       TextWrapping="Wrap" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="MP4" FontWeight="SemiBold" Foreground="{DynamicResource ThemeAccentBrush}" />
                            <TextBlock Grid.Row="1" Grid.Column="1"
                                       Text="Read-only integration: scan, inspect, cache, library overview, and rename planning through ffprobe metadata. MP4 files are not converted, remuxed, muxed, or property-edited by MKV Orchestrator."
                                       TextWrapping="Wrap" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Safety" FontWeight="SemiBold" Foreground="{DynamicResource ThemeAccentBrush}" />
                            <TextBlock Grid.Row="2" Grid.Column="1"
                                       Text="Execution workflows are preview-first so file changes can be reviewed before applying them."
                                       TextWrapping="Wrap" />
                          </Grid>
                        </StackPanel>
                      </Border>

                      <Border Classes="panel">
                        <StackPanel Spacing="10">
                          <TextBlock Text="Integrations &amp; Attribution" Classes="section-header" />

                          <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="12">
                            <Border Grid.Row="0" Grid.Column="0"
                                    Background="{DynamicResource ThemePanelBackgroundBrush}"
                                    BorderBrush="{DynamicResource ThemeBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="10">
                              <Grid ColumnDefinitions="92,*" ColumnSpacing="12">
                                <Border Grid.Column="0"
                                        Width="82"
                                        Height="72"
                                        Background="{DynamicResource ThemeWindowBackgroundBrush}"
                                        BorderBrush="{DynamicResource ThemeBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                  <Image Source="/Assets/Logos/tmdb.png"
                                         MaxHeight="58"
                                         MaxWidth="72"
                                         Stretch="Uniform"
                                         ToolTip.Tip="TMDB" />
                                </Border>
                                <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                                  <TextBlock Text="TMDB" FontWeight="SemiBold" />
                                  <TextBlock Text="This product uses the TMDB API but is not endorsed or certified by TMDB."
                                             TextWrapping="Wrap"
                                             Classes="muted" />
                                </StackPanel>
                              </Grid>
                            </Border>

                            <Border Grid.Row="0" Grid.Column="1"
                                    Background="{DynamicResource ThemePanelBackgroundBrush}"
                                    BorderBrush="{DynamicResource ThemeBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="10">
                              <Grid ColumnDefinitions="92,*" ColumnSpacing="12">
                                <Border Grid.Column="0"
                                        Width="82"
                                        Height="72"
                                        Background="{DynamicResource ThemeWindowBackgroundBrush}"
                                        BorderBrush="{DynamicResource ThemeBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                  <Image Source="/Assets/Logos/tvdb.png"
                                         MaxHeight="58"
                                         MaxWidth="72"
                                         Stretch="Uniform"
                                         ToolTip.Tip="TheTVDB" />
                                </Border>
                                <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                                  <TextBlock Text="TheTVDB" FontWeight="SemiBold" />
                                  <TextBlock Text="Metadata provided by TheTVDB."
                                             TextWrapping="Wrap"
                                             Classes="muted" />
                                </StackPanel>
                              </Grid>
                            </Border>

                            <Border Grid.Row="1" Grid.Column="0"
                                    Background="{DynamicResource ThemePanelBackgroundBrush}"
                                    BorderBrush="{DynamicResource ThemeBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="10">
                              <Grid ColumnDefinitions="92,*" ColumnSpacing="12">
                                <Border Grid.Column="0"
                                        Width="82"
                                        Height="72"
                                        Background="{DynamicResource ThemeWindowBackgroundBrush}"
                                        BorderBrush="{DynamicResource ThemeBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                  <Image Source="/Assets/Logos/mkvtoolnix.png"
                                         MaxHeight="62"
                                         MaxWidth="64"
                                         Stretch="Uniform"
                                         ToolTip.Tip="MKVToolNix" />
                                </Border>
                                <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                                  <TextBlock Text="MKVToolNix" FontWeight="SemiBold" />
                                  <TextBlock Text="Used for MKV remuxing, metadata editing, extraction, and analysis."
                                             TextWrapping="Wrap"
                                             Classes="muted" />
                                </StackPanel>
                              </Grid>
                            </Border>

                            <Border Grid.Row="1" Grid.Column="1"
                                    Background="{DynamicResource ThemePanelBackgroundBrush}"
                                    BorderBrush="{DynamicResource ThemeBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="10">
                              <Grid ColumnDefinitions="92,*" ColumnSpacing="12">
                                <Border Grid.Column="0"
                                        Width="82"
                                        Height="72"
                                        Background="{DynamicResource ThemeWindowBackgroundBrush}"
                                        BorderBrush="{DynamicResource ThemeBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                  <Image Source="/Assets/Logos/ffmpeg.png"
                                         MaxHeight="52"
                                         MaxWidth="66"
                                         Stretch="Uniform"
                                         ToolTip.Tip="FFmpeg" />
                                </Border>
                                <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                                  <TextBlock Text="FFmpeg / ffprobe" FontWeight="SemiBold" />
                                  <TextBlock Text="Used for metadata analysis, including MP4 read-only inspection."
                                             TextWrapping="Wrap"
                                             Classes="muted" />
                                </StackPanel>
                              </Grid>
                            </Border>
                          </Grid>
                        </StackPanel>
                      </Border>

                      <Border Classes="panel">
                        <StackPanel Spacing="4">
                          <TextBlock Text="Attribution Notice" Classes="section-header" />
                          <TextBlock Text="Provider and tool logos are displayed for attribution only. MKV Orchestrator is not endorsed or certified by TMDB, TheTVDB, MKVToolNix, or FFmpeg."
                                     TextWrapping="Wrap"
                                     Classes="muted" />
                        </StackPanel>
                      </Border>
                    </StackPanel>
                  </ScrollViewer>
                </TabItem>
              </TabControl>
            </DockPanel>
          </Border>

        </Grid>
</UserControl>
