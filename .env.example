# Local bind-mount defaults used by docker-compose.yml.
MKVO_MEDIA_PATH=./tmp/docker-media
MKVO_DOWNLOADS_PATH=./tmp/docker-downloads
MKVO_CONFIG_PATH=./tmp/docker-config
MKVO_SOURCE_ROOTS=downloads=/downloads

# Optional: run as a specific user so files on mounted shares are not root-owned.
# PUID=99
# PGID=100
# UMASK=022

# Optional: require HTTP basic auth for the web UI and API.
# MKVO_AUTH_USERNAME=admin
# MKVO_AUTH_PASSWORD=change-me

# Optional NAS/CIFS deployment values used with docker-compose.nas.example.yml.
# Copy this file to .env locally, then edit these paths for your server.
MKVO_MEDIA_SHARE=//server/media
MKVO_DOWNLOADS_SHARE=//server/downloads/media
MKVO_CIFS_OPTIONS=guest,vers=3.0

# If your SMB share requires credentials, keep them only in your local .env.
# Example:
# MKVO_CIFS_OPTIONS=username=myuser,password=mypassword,vers=3.0
